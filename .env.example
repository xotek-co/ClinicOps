# Supabase - Get these from your project at https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required only for seed script (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Analytics Assistant (Admin only) - get key at openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key
# Supabase direct DB connection - from Project Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
